# AeroGuard-PHM environment example
# Copy to .env for local development only. Do not commit real secrets.

# Optional path to the frozen public manifest used by the API.
AEROGUARD_MANIFEST=artifacts/final_release/frozen_system_manifest.json

# Optional API bind settings for local development.
AEROGUARD_API_HOST=127.0.0.1
AEROGUARD_API_PORT=8000

# Optional local directory for inference logs if an application wrapper writes them.
AEROGUARD_LOG_DIR=reports/inference

